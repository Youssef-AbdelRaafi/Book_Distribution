# JWT Secret Key (Must be at least 32 characters long)
# Generate with: openssl rand -base64 48
JWT_SIGNING_KEY=ChangeThisToASecretKeyOfAtLeast32Characters!

# Admin Password Hash (PBKDF2 format)
# To generate: run the API locally in Development mode, then visit:
#   http://localhost:5291/api/setup/hash?password=YourPassword
#
# NOTE: The hash uses $ as delimiter. If using a .env file with docker-compose,
# write $$ instead of $, e.g.: pbkdf2-sha256$$100000$$salt$$hash
ADMIN_PASSWORD_HASH=pbkdf2-sha256$100000$zf6GX/k90ONeWOV1+c5YAw==$awRY2N/tmPNKIeN7yZkZoDDurRFkW+VASFThNz+kD1k=
