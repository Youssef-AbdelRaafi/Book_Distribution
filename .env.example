# ══════════════════════════════════════════════════════════════
#  إعدادات نشر التطبيق — Application Deployment Configuration
# ══════════════════════════════════════════════════════════════
#  انسخ هذا الملف إلى .env وغير القيم حسب جهاز العميل
#  Copy this file to .env and fill in real values for client
# ══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────
#  JWT Secret Key — مفتاح توقيع التوكن (أقل حاجة 32 حرف)
#  Generate with: openssl rand -base64 48
# ──────────────────────────────────────────────────────────────
JWT_SIGNING_KEY=JttZqGVo4xrfwiuy0BbH8xkL21sO9YiNI7J3LWB7YqD+CgPuuMeF2E2vU5KoeYHr

# ──────────────────────────────────────────────────────────────
#  Admin Password Hash — باسورد المدير (اختياري)
#  لو محططش ADMIN_PASSWORD_HASH، الباسورد الافتراضي: admin / admin@123
#  لكن للعميل، الأفضل تحدد باسورد وتولد الهاش بتاعه:
#
#  🖥️  توليد الهاش (شغّل التطبيق محليًا وافتح الرابط):
#     http://localhost:5291/api/setup/hash?password=كلمة_السر
#
#  ⚠️  الهاش فيه علامات $. في ملف .env اكتب $$ بدل $
#     مثال:
#       pbkdf2-sha256$$100000$$salt$$hash
# ──────────────────────────────────────────────────────────────
ADMIN_PASSWORD_HASH=pbkdf2-sha256$$100000$$7G950AlB8E36k20Wr8Krpg==$$oO/t0obECeBVl1wjS7CMncxqFznL0ToShVqoSQWzvfE=

# ──────────────────────────────────────────────────────────────
#  Backup settings — إعدادات النسخ الاحتياطي
# ──────────────────────────────────────────────────────────────
# BACKUP_ENABLED=true       # true/false
